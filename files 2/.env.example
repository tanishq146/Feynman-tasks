# ── FEYNMAN Backend Environment Variables ──────────────────────

# Your Anthropic API key — get it from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the server runs on (default: 3001)
PORT=3001

# Allowed frontend origin for CORS (use * for development, set your domain in production)
# Example: ALLOWED_ORIGIN=https://feynman.yourdomain.com
ALLOWED_ORIGIN=*

# Default system prompt (can be overridden per-request from the frontend)
# You will customize this with your actual prompt
DEFAULT_SYSTEM_PROMPT=You are FEYNMAN, an AI-powered second brain. You help users think, connect ideas, capture knowledge, and reason through problems. Be concise, sharp, and insightful. Avoid filler phrases.
